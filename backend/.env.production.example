# If you want Django to load this file directly, start the backend with:
# DOTENV_FILE=.env.production ENVIRONMENT=production

# Runtime mode
ENVIRONMENT=production

# Django core
DJANGO_SECRET_KEY=change-this-to-a-long-random-secret
DEBUG=False

# Origins and host allowlist
APP_ORIGIN=https://survey.mindspear.app
API_ORIGIN=https://survey.mindspear.app
PUBLIC_APP_URL=https://survey.mindspear.app
API_BASE_URL=https://survey.mindspear.app/api
ALLOWED_HOSTS=survey.mindspear.app
CORS_ALLOWED_ORIGINS=https://survey.mindspear.app
CSRF_TRUSTED_ORIGINS=https://survey.mindspear.app

# Database
DB_ENGINE=django.db.backends.postgresql
DB_NAME=questizsurvey_db
DB_USER=questizsurvey_user
DB_PASSWORD=change-this-database-password
DB_HOST=127.0.0.1
DB_PORT=5432

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
CELERY_BROKER_URL=redis://127.0.0.1:6379/2
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/2
CELERY_TASK_ALWAYS_EAGER=False
CELERY_TASK_EAGER_PROPAGATES=True

# Reverse proxy, cookies, and browser hardening
USE_X_FORWARDED_HOST=True
CSRF_COOKIE_SECURE=True
SESSION_COOKIE_SECURE=True
SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False
SECURE_REFERRER_POLICY=strict-origin-when-cross-origin
SECURE_CONTENT_TYPE_NOSNIFF=True
X_FRAME_OPTIONS=DENY
AUTH_REFRESH_COOKIE_NAME=questiz_refresh
AUTH_REFRESH_COOKIE_PATH=/api/auth/
AUTH_REFRESH_COOKIE_SECURE=True
AUTH_REFRESH_COOKIE_SAMESITE=Lax
AUTH_REFRESH_COOKIE_DOMAIN=
AI_SECRETS_ALLOW_DATABASE=False
GUNICORN_BIND=127.0.0.1:8010
GUNICORN_WORKERS=3
GUNICORN_TIMEOUT=120

# Email / SMTP
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.your-mail-server.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-smtp-username
EMAIL_HOST_PASSWORD=your-smtp-password
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
DEFAULT_FROM_EMAIL=no-reply@mindspear.app

# AI provider secrets: production should use environment variables only
OPENAI_API_KEY=
OPENAI_RESPONSES_MODEL=gpt-5-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-7-sonnet-latest

# Stripe
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# bKash
BKASH_APP_KEY=
BKASH_APP_SECRET=
BKASH_USERNAME=
BKASH_PASSWORD=
# Use your merchant-provided live bKash base URL here, not the sandbox URL.
BKASH_BASE_URL=
