# Django Settings
DJANGO_SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=True
APP_ORIGIN=http://localhost:5555
API_ORIGIN=http://localhost:8000
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:5555,http://127.0.0.1:5555
CSRF_TRUSTED_ORIGINS=http://localhost:5555,http://127.0.0.1:5555,http://localhost:8000,http://127.0.0.1:8000

# Database Configuration
DB_ENGINE=django.db.backends.postgresql
DB_NAME=questizsurvey_db
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# Redis Configuration (for channels and caching)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# Public URLs used in emails and survey links
PUBLIC_APP_URL=http://localhost:5555
API_BASE_URL=http://localhost:8000/api

# Email Configuration
# For local development without a real mail server, keep the console backend.
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.your-mail-server.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-smtp-username
EMAIL_HOST_PASSWORD=your-smtp-password
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
DEFAULT_FROM_EMAIL=no-reply@yourdomain.com

# Celery / Redis
CELERY_BROKER_URL=redis://127.0.0.1:6379/2
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/2
# Set to True only for tests or when you want tasks to run inline.
CELERY_TASK_ALWAYS_EAGER=False
CELERY_TASK_EAGER_PROPAGATES=True

# Reverse proxy / cookies
USE_X_FORWARDED_HOST=False
CSRF_COOKIE_SECURE=False
SESSION_COOKIE_SECURE=False
GUNICORN_BIND=127.0.0.1:8010
GUNICORN_WORKERS=3
GUNICORN_TIMEOUT=120

# Optional ChatGPT-powered analytics insights
# Leave blank to disable AI insight generation on analytics endpoints.
OPENAI_API_KEY=
OPENAI_RESPONSES_MODEL=


# Stripe
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
BKASH_APP_KEY=
BKASH_APP_SECRET=
BKASH_USERNAME=
BKASH_PASSWORD=
BKASH_BASE_URL=https://tokenized.sandbox.bka.sh/v1.2.0-beta
